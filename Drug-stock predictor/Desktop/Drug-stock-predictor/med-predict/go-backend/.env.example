# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medpredict
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# Server
PORT=8080
GIN_MODE=debug
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Logging
